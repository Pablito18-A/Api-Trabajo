<div class="offcanvas offcanvas-end" id="demo">
  <!-- 1. Cabecera limpia -->
  <div class="offcanvas-header">
    <h1 class="offcanvas-title">Carrito</h1>
    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas"></button>
  </div>

  <!-- 2. Cuerpo del offcanvas con flex column y h-100 para ocupar toda la altura -->
  <div class="offcanvas-body d-flex flex-column justify-content-between p-3">
    
    <!-- Contenedor donde se listarán los productos (crecerá según los items) -->
    <main class="flex-grow-1 overflow-auto">
      <!-- Aquí irán los productos agregados al carrito -->
      <p class="text-muted">Tu carrito está vacío.</p>
    </main>

    <!-- 3. Footer pegado siempre abajo -->
    <footer class="mt-auto border-top pt-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="fw-bold fs-5">Total:</span>
        <span class="fw-bold fs-5 text-success">$0.00</span>
      </div>
      <button class="btn btn-outline-danger w-100">Vaciar carrito</button>
    </footer>

  </div>
</div>